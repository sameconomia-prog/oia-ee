DATABASE_URL=postgresql://oiaee:oiaee_dev@localhost:5432/oia_ee
TEST_DATABASE_URL=sqlite+pysqlite:///:memory:

ENVIRONMENT=development
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth
JWT_SECRET=cambia-esto-por-un-secreto-largo
ADMIN_API_KEY=
CORS_ORIGIN=http://localhost:3000

# Scheduler (activa jobs automáticos en Railway — siempre true en prod)
ENABLE_SCHEDULER=false
ANUIES_CSV_PATH=
STPS_CSV_PATH=

# ─── LLM / IA ────────────────────────────────────────────────────────────────
# Clasificador Groq (primario, gratis) — https://console.groq.com
GROQ_API_KEY=gsk_...
# Fallback Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_CLASSIFIER=claude-haiku-4-5-20251001
CLAUDE_MODEL_REPORT=claude-sonnet-4-6

# ─── Fuentes de noticias (Radar P8) ──────────────────────────────────────────
# Grok API (x.ai) — https://console.x.ai/  [distinto de GROQ]
GROK_API_KEY=xai-...
# NewsAPI — https://newsapi.org/register  (100 req/día gratis)
NEWSAPI_KEY=...

# ─── Datos económicos (P2A/P2B) ──────────────────────────────────────────────
# INEGI BIE — https://www.inegi.org.mx/servicios/api_biinegi.html  (~24h para token)
INEGI_API_TOKEN=...

# ─── Infraestructura (P3) ────────────────────────────────────────────────────
# Redis para rate limiting — Railway: New Service → Redis (URL autoinyectada)
# Local: redis://localhost:6379 | Upstash: rediss://...
REDIS_URL=redis://localhost:6379

# ─── Email alertas (P0) ──────────────────────────────────────────────────────
# Resend — https://resend.com  (verificar dominio oia-ee.mx)
RESEND_API_KEY=re_...

# ─── Otros ───────────────────────────────────────────────────────────────────
VOYAGE_API_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=
SENTRY_DSN=

# Frontend (.env.local)
NEXT_PUBLIC_ADMIN_KEY=misma-clave-que-ADMIN_API_KEY
