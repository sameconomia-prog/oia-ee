DATABASE_URL=postgresql://oiaee:oiaee_dev@localhost:5432/oia_ee
TEST_DATABASE_URL=sqlite+pysqlite:///:memory:

ENVIRONMENT=development
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth
JWT_SECRET=cambia-esto-por-un-secreto-largo
ADMIN_API_KEY=
CORS_ORIGIN=http://localhost:3000

# Scheduler (activa jobs automáticos en Railway — siempre true en prod)
ENABLE_SCHEDULER=false
ANUIES_CSV_PATH=
STPS_CSV_PATH=

# ─── LLM / IA ────────────────────────────────────────────────────────────────
# Clasificador Radar — FallbackClient usa los que estén configurados (en orden)
# Groq (primario, más rápido) — https://console.groq.com
GROQ_API_KEY=gsk_...
# DeepSeek — https://platform.deepseek.com  (sin VPN)
DEEPSEEK_API_KEY=sk-...
# Qwen/Alibaba — https://dashscope.aliyun.com  (sin VPN)
QWEN_API_KEY=sk-...
# ZAI/GLM — https://z.ai  (sin VPN, OAuth Google)
ZAI_API_KEY=...
# OpenRouter — https://openrouter.ai  (modelos :free)
OPENROUTER_API_KEY=sk-or-v1-...
# Cerebras — https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk-...
# Cohere — https://dashboard.cohere.com
COHERE_API_KEY=...
# Mistral — https://console.mistral.ai
MISTRAL_API_KEY=...
# Fallback Anthropic Claude (último recurso) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_CLASSIFIER=claude-haiku-4-5-20251001
CLAUDE_MODEL_REPORT=claude-sonnet-4-6

# ─── Fuentes de noticias (Radar P8) ──────────────────────────────────────────
# Grok API (x.ai) — https://console.x.ai/  [distinto de GROQ]
GROK_API_KEY=xai-...
# NewsAPI — https://newsapi.org/register  (100 req/día gratis)
NEWSAPI_KEY=...

# ─── Datos económicos (P2A/P2B) ──────────────────────────────────────────────
# INEGI BIE — https://www.inegi.org.mx/servicios/api_biinegi.html  (~24h para token)
INEGI_API_TOKEN=...

# ─── Infraestructura (P3) ────────────────────────────────────────────────────
# Redis para rate limiting — Railway: New Service → Redis (URL autoinyectada)
# Local: redis://localhost:6379 | Upstash: rediss://...
REDIS_URL=redis://localhost:6379

# ─── Email alertas (P0) ──────────────────────────────────────────────────────
# Resend — https://resend.com  (verificar dominio oia-ee.mx)
RESEND_API_KEY=re_...

# ─── Otros ───────────────────────────────────────────────────────────────────
VOYAGE_API_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=
SENTRY_DSN=

# Frontend (.env.local)
NEXT_PUBLIC_ADMIN_KEY=misma-clave-que-ADMIN_API_KEY
NEXT_PUBLIC_SITE_URL=https://oia-ee.mx
